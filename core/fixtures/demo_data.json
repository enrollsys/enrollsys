  {
    "model": "core.faq",
    "pk": 1,
    "fields": {
      "question": "Как подать заявление?",
      "answer": "Создайте личный кабинет, выберите направление подготовки и отправьте заявку. После отправки она появится у методиста на проверке.",
      "order": 1,
      "is_active": true
    }
  },
  {
    "model": "core.faq",
    "pk": 2,
    "fields": {
      "question": "Можно ли загрузить документы онлайн?",
      "answer": "Да, документы прикрепляются к конкретной заявке в личном кабинете. Методист увидит их в разделе проверки документов.",
      "order": 2,
      "is_active": true
    }
  },
  {
    "model": "core.faq",
    "pk": 3,
    "fields": {
      "question": "Как узнать статус заявки?",
      "answer": "Статус заявки отображается в личном кабинете абитуриента: подана, на рассмотрении, принята или отклонена.",
      "order": 3,
      "is_active": true
    }
  },
  {
    "model": "core.faq",
    "pk": 4,
    "fields": {
      "question": "Нужны ли оригиналы документов?",
      "answer": "Для предварительной проверки достаточно электронных копий. Оригиналы предоставляются в приемную комиссию в сроки, указанные в правилах приема.",
      "order": 4,
      "is_active": true
    }
  },
  {
    "model": "core.faq",
    "pk": 5,
    "fields": {
